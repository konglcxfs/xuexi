{
  "name": "@xuexi/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "smoke": "tsx src/smoke.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@xuexi/ai-adapter": "workspace:*",
    "@xuexi/knowledge-base": "workspace:*",
    "@xuexi/learning-engine": "workspace:*",
    "@xuexi/shared": "workspace:*",
    "fastify": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
